APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Production: APP_DEBUG=false, APP_URL=https://domain-anda.tld (harus cocok dengan URL asli)
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
# Lokal: 127.0.0.1 — shared hosting: sering "localhost" (lihat panel hosting)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Opsional: Google reCAPTCHA v2 (checkbox). Kosongkan = tantangan matematika di UI (cocok untuk demo lokal).
# Buat kunci di https://www.google.com/recaptcha/admin — pilih reCAPTCHA v2 "I'm not a robot"
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Lokal dengan Mailpit/Herd. Production: smtp host/port hosting (bukan mailpit).
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Google OAuth (Socialite). Kosong = fitur login Google tidak dikonfigurasi.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# DOKU pembayaran. Kosong = integrasi tidak aktif / sandbox default dari config.
DOKU_CLIENT_ID=
DOKU_SECRET_KEY=
DOKU_BASE_URL=https://api-sandbox.doku.com
DOKU_ENVIRONMENT=sandbox
DOKU_PAYMENT_DUE_MINUTES=60

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
